# ============================================================
# OpsLens backend — variables d'environnement
# Copie ce fichier en .env et remplis avec tes vraies valeurs.
# Le .env est ignoré par git, ne sera jamais committé.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# --- WAHA gateway (le service Coolify déjà en ligne) ---
WAHA_BASE_URL=https://osm0pvu7wmne4ed52fxjirdn.2.24.15.60.sslip.io
WAHA_API_KEY=replace_with_your_waha_api_key
WAHA_SESSION_NAME=default

# Secret partagé optionnel pour signer le webhook entrant (header X-Webhook-Secret).
# Laisse vide pour démarrer, on l'activera plus tard.
WAHA_WEBHOOK_SECRET=

# --- Pilote ADS ---
# ID du groupe WhatsApp à surveiller (filtre dur en entrée du webhook).
PILOT_GROUP_ID=120363142540472721@g.us

# UUID de la company dans Supabase (table companies).
# À remplir après avoir bootstrappé la company ADS (voir README).
COMPANY_ID=00000000-0000-0000-0000-000000000000

# --- App ---
LOG_LEVEL=INFO
